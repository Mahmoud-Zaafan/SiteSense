# =============================================================================
# Eagle Vision — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# --- TimescaleDB ---
POSTGRES_USER=cem_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=construction_monitor
DB_HOST=timescaledb
DB_PORT=5432

# --- Hugging Face Auth (for DINOv3 model download) ---
HF_TOKEN=your_huggingface_token_here

# --- CV Inference ---
VIDEO_SOURCE=/data/test_video.mp4
DEVICE=cuda
MODEL_PATH=/models

# --- Kafka Topics ---
KAFKA_TOPIC_RAW=equipment.telemetry.raw
KAFKA_TOPIC_AGGREGATED=equipment.state.aggregated
